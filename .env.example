# TikTok Business API long-lived OAuth access token
TIKTOK_ACCESS_TOKEN=replace_me

# Optional overrides
TIKTOK_ADVERTISER_ID=7441895227339718673
TIKTOK_BASE_URL=https://business-api.tiktok.com/open_api/v1.3
TIKTOK_CAMPAIGN_NAME_SUBSTRING=acemate_Views
TIKTOK_SOURCE_CAMPAIGN_NAME=acemate_Views_2026_03_12
TIKTOK_POST_LIST_ENDPOINTS=/spark_ad/post/list/,/tt_video/list/
# Optional: fresh TikTok video auth code used for /tt_video/authorize/ before latest lookup
TIKTOK_VIDEO_AUTH_CODE=
# Optional: set to 1 to allow fallback to latest existing ad item when post endpoints are stale
TIKTOK_ALLOW_AD_ITEM_FALLBACK=0

# Optional Slack notification at end of successful run
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=C0A49B277UK
TIKTOK_MANAGE_CAMPAIGN_URL=https://ads.tiktok.com/i18n/manage/campaign?aadvid=7441895227339718673&lifetime=1
